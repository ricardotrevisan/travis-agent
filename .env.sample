# -----------------------------
# Evolution API stack
# -----------------------------
SERVER_NAME=evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080
AUTHENTICATION_API_KEY=change-me
LANGUAGE=en
WEBHOOK_GLOBAL_ENABLED=false

EVOLUTION_POSTGRES_DATABASE=evolution_api
EVOLUTION_POSTGRES_USERNAME=postgres
EVOLUTION_POSTGRES_PASSWORD=change-me
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:change-me@evolution-postgres:5432/evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379
CACHE_REDIS_TTL=604800
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

REDIS_HOST_PORT=6380

# -----------------------------
# Agent -> Evolution
# -----------------------------
EVOLUTION_URL=http://api:8080
EVOLUTION_APIKEY=change-me
WA_AGENT_EVOLUTION_APIKEY=change-me
INSTANCE=Travis
WA_AGENT_INSTANCE=Travis

# -----------------------------
# OpenAI
# -----------------------------
OPENAI_API_KEY=change-me
WA_AGENT_OPENAI_API_KEY=change-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BETA_HEADER=responses-2024-12-17
OPENAI_RESPONSES_MODEL=gpt-5-mini
AGENT_NAME=Travis
AGENT_PERSONA_SARCASM=light
OPENAI_RESPONSES_MODEL_SECOND=gpt-5-mini
OPENAI_OCR_MODEL=gpt-4.1
OPENAI_IMAGE_MODEL=gpt-image-1

# -----------------------------
# Voice (STT + TTS)
# -----------------------------
VOICE_API_URL=http://host.docker.internal:8000
VOICE_API_TIMEOUT=180
VOICE_LANGUAGE_DEFAULT=pt

# -----------------------------
# n8n Schedule Alerts (V2 Skill)
# -----------------------------
N8N_SCHEDULE_WEBHOOK_URL=
N8N_SCHEDULE_TIMEOUT=15
TASK_CALLBACK_SECRET=
SCHEDULE_TIMEZONE=America/Sao_Paulo

# -----------------------------
# MCP
# -----------------------------
MCP_URL=http://host.docker.internal:8010/mcp
MCP_TOOLS_CACHE_TTL=300
MCP_GMAIL_USER_EMAIL=rc.trevis@gmail.com

# -----------------------------
# Final interpreter (LLM)
# -----------------------------
FINAL_INTERPRETER_ENABLED=true
FINAL_INTERPRETER_MODEL=gpt-5-mini
FINAL_INTERPRETER_MAX_CHARS=6000

# -----------------------------
# Tool tuning
# -----------------------------
SEARCH_TIMEOUT=10
SEARCH_MAX_RESULTS=3
SEARCH_MAX_CHARS=600
MAX_TOOL_CONTEXT_CHARS=12000
LOCAL_SUMMARY_MAX_SENTENCES=5
LOCAL_SUMMARY_MAX_CHARS=1500

# -----------------------------
# Session / memory tuning
# -----------------------------
SESSION_MAX_USERS=500
MEDIA_TTL_SECONDS=900
SESSION_MAX_STORED_TURNS=30
SESSION_RECENT_TURNS_FOR_PROMPT=10
SESSION_SUMMARIZER_MODE=local
SESSION_SUMMARY_MAX_CHARS=1500
SESSION_SUMMARY_MAX_TOKENS=300

# -----------------------------
# Redis persistence for agent context
# -----------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PREFIX=agent
WEBHOOK_DEDUPE_TTL_SECONDS=300
GARMINTOKENS=~/.garminconnect
GARMINTOKENS_HOST_PATH=/home/your-user/.garminconnect

# -----------------------------
# Allow List
# -----------------------------
ALLOWED_WHATSAPP_NUMBERS=+5511999999999
WA_AGENT_ALLOWED_SENDERS=5511999999999
